            "type": "dart"
        },
        {
            "name": "school_app (Wi-Fi Debug)",
            "request": "launch",
            "type": "dart",
            "toolArgs": [
                "--vm-service-port", "8181"
            ]
        },
        {
            "name": "school_app (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "school_app (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        }
    ]
